# ─── GEO HELP BOARD ENDPOINT TESTS ───────────────────────────────────────────
# This suite follows your existing REST Client testing style.
# Roles expected by backend: STUDENT + PROFESSOR allowed, ALUMNI denied.

@baseUrl = http://localhost:3000

# Paste fresh access tokens after login
@studentToken = REPLACE_WITH_STUDENT_ACCESS_TOKEN
@professorToken = REPLACE_WITH_PROFESSOR_ACCESS_TOKEN
@alumniToken = REPLACE_WITH_ALUMNI_ACCESS_TOKEN
@adminToken = REPLACE_WITH_ADMIN_ACCESS_TOKEN

# IDs captured from create responses
@spotId = REPLACE_WITH_CREATED_SPOT_ID

###
# 0) AUTH CHECK: no token should fail (401)
GET {{baseUrl}}/geo-help-board/spots/popular

###
# 1) ROLE CHECK: alumni should fail (403)
GET {{baseUrl}}/geo-help-board/spots/popular
Authorization: Bearer {{alumniToken}}

###
# 2) CREATE SPOT as STUDENT (201)
POST {{baseUrl}}/geo-help-board/spots
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "title": "Széchenyi Square Study Spot",
  "description": "Nice outdoor benches and cafés nearby",
  "city": "Pecs",
  "address": "Széchenyi tér, Pécs",
  "latitude": 46.072734,
  "longitude": 18.232266,
  "category": "STUDY_SPACE"
}

###
# 3) CREATE SPOT as PROFESSOR (201)
POST {{baseUrl}}/geo-help-board/spots
Content-Type: application/json
Authorization: Bearer {{professorToken}}

{
  "title": "University Library Quiet Zone",
  "description": "Quiet reading space with charging points",
  "city": "Pecs",
  "address": "Universitas u., Pécs",
  "latitude": 46.074119,
  "longitude": 18.206556,
  "category": "LIBRARY"
}

###
# 4) REVIEW FIRST SPOT as ADMIN (200)
PATCH {{baseUrl}}/geo-help-board/spots/{{spotId}}/review
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "isVerified": true
}

###
# 5) POPULAR SPOTS (200)
GET {{baseUrl}}/geo-help-board/spots/popular?city=Pecs&limit=10
Authorization: Bearer {{studentToken}}

###
# 6) POPULAR SPOTS with CATEGORY FILTER + PAGINATION (200)
GET {{baseUrl}}/geo-help-board/spots/popular?city=Pecs&category=LIBRARY&limit=10&page=1
Authorization: Bearer {{studentToken}}

###
# 7) NEARBY SPOTS around Pécs center + PAGINATION (200)
GET {{baseUrl}}/geo-help-board/spots/nearby?latitude=46.072734&longitude=18.232266&radiusKm=3&city=Pecs&limit=10&page=1
Authorization: Bearer {{studentToken}}

###
# 8) RECORD VISIT (201)
POST {{baseUrl}}/geo-help-board/spots/{{spotId}}/visit
Authorization: Bearer {{studentToken}}

###
# 9) VERIFY POPULARITY CHANGED (200)
GET {{baseUrl}}/geo-help-board/spots/popular?city=Pecs&limit=10
Authorization: Bearer {{studentToken}}

###
# 10) VALIDATION CHECK: invalid latitude should fail (400)
GET {{baseUrl}}/geo-help-board/spots/nearby?latitude=146.0&longitude=18.232266&radiusKm=3
Authorization: Bearer {{studentToken}}

###
# 11) VALIDATION CHECK: radius above max should fail (400)
GET {{baseUrl}}/geo-help-board/spots/nearby?latitude=46.072734&longitude=18.232266&radiusKm=55
Authorization: Bearer {{studentToken}}

###
# 12) NOT FOUND VISIT CHECK (should fail)
POST {{baseUrl}}/geo-help-board/spots/00000000-0000-0000-0000-000000000000/visit
Authorization: Bearer {{studentToken}}

# Notes:
# - Obtain tokens from login endpoints before running this file.
# - Copy spot id returned by create endpoint into @spotId.
# - If you want deterministic baseline data, run seed with GEO_HELP_BOARD_SEED=true.
