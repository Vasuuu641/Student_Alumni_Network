# ─── REPLY 2 (top level) ─────────────────────────────────────────────────────

POST {{baseUrl}}/threads/{{threadId}}/replies
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "content": "The Bode plot questions are always in the practical. Practice sketching them by hand — know how poles and zeros affect the slope of the magnitude plot. A pole adds minus 20dB per decade after the corner frequency."
}

###
# ─── REPLY 2a (nested under Reply 2) ────────────────────────────────────────

POST {{baseUrl}}/threads/{{threadId}}/replies
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "content": "The phase plot is just as important as the magnitude plot. Remember a pole contributes minus 90 degrees of phase shift and a zero contributes plus 90 degrees.",
  "parentReplyId": "{{reply2Id}}"
}

