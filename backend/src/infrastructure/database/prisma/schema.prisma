// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  firstName     String
  lastName      String
  role          Role
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  student       Student?
  alumni        Alumni?
  professor     Professor?
  notesOwned    Note[]   @relation("NoteOwner")
  notesShared   NoteCollaborator[]
  noteVersions  NoteVersion[] @relation("NoteVersionAuthor")
  noteActivities NoteActivity[] @relation("NoteActivityActor")
}

model Student {
  userId              String @id
  major               String
  yearOfGraduation    Int?    @map("year_of_graduation")
  jobTitle            String? @map("job_title")
  company             String? 
  interests           String[]
  faculty             String? @map("faculty")
  bio                 String?
  profilePictureUrl   String? @map("profile_picture_url")

  user User @relation(fields: [userId], references: [id])
}

model Alumni {
  userId            String @id
  yearOfGraduation  Int?     @map("year_of_graduation")
  major             String?
  company           String?
  jobTitle          String?  @map("job_title")
  bio               String?
  interests         String[]
  profilePictureUrl String? @map("profile_picture_url")
  isAnonymous       Boolean @default(false)
  anonymousName     String? @map("anonymous_name")

  user User @relation(fields: [userId], references: [id])
}

model Professor {
  userId            String @id
  faculty           String 
  jobTitle          String  @map("job_title")
  bio               String?
  interests         String[]
  profilePictureUrl String? @map("profile_picture_url")

  user User @relation(fields: [userId], references: [id])
}

enum Role {
  STUDENT
  ALUMNI
  PROFESSOR
  ADMIN
}

model AuthorizedUser {
  id        String   @id @default(uuid())
  email     String   @unique
  role      Role
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//Notes feature integration

enum NotePermissionRole {
  OWNER
  EDITOR
  VIEWER
}

enum NoteStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum NoteLinkSource {
  MANUAL
  AI
}

model Note {
  id        String     @id @default(uuid())
  title     String
  ownerId   String
  status    NoteStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  owner     User       @relation("NoteOwner", fields: [ownerId], references: [id])
  collaborators NoteCollaborator[]
  versions   NoteVersion[]
  activities NoteActivity[]

  @@index([ownerId])
  @@index([updatedAt])
}

model NoteCollaborator {
  noteId    String
  userId    String
  role      NotePermissionRole @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  note Note @relation(fields: [noteId], references: [id])

  @@id([noteId, userId])
  @@index([userId])
}

model NoteVersion {
  id            String   @id @default(uuid())
  noteId        String
  versionNumber Int
  snapshotJson  Json
  authorId      String
  createdAt     DateTime @default(now())

  note          Note     @relation(fields: [noteId], references: [id])
  author        User     @relation("NoteVersionAuthor", fields: [authorId], references: [id])

  @@unique([noteId, versionNumber])
  @@index([noteId])
  @@index([authorId])
}

model NoteActivity {
  id           String   @id @default(uuid())
  noteId       String
  actorId      String
  action       String
  metadataJson Json?
  createdAt    DateTime @default(now())

  note         Note     @relation(fields: [noteId], references: [id])
  actor        User     @relation("NoteActivityActor", fields: [actorId], references: [id])

  @@index([noteId])
  @@index([actorId])
  @@index([createdAt])
}